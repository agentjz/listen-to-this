page {
  min-height: 100%;
  color: #172033;
  background: #f6f7fb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

view,
text,
input,
textarea {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f6f7fb;
}

.section {
  margin-bottom: 28rpx;
}

.panel {
  padding: 28rpx;
  border: 1rpx solid #e3e7f3;
  border-radius: 8rpx;
  background: #ffffff;
}

.title {
  color: #172033;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 52rpx;
}

.subtitle {
  margin-top: 8rpx;
  color: #667085;
  font-size: 26rpx;
  line-height: 38rpx;
}

.muted {
  color: #667085;
}

.primary-text {
  color: #0284c7;
}

.stack {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.input-placeholder {
  color: #98a2b3;
  line-height: 48rpx;
}
