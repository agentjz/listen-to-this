.home-page {
  padding-top: 44rpx;
}

.hero {
  padding: 36rpx 0 28rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.entry-card {
  display: flex;
  width: 100%;
  min-height: 220rpx;
  margin: 0;
  padding: 24rpx 12rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #0284c7;
  background: #ffffff;
  line-height: 1.4;
}

.entry-title {
  color: #0284c7;
  font-size: 32rpx;
  font-weight: 650;
  line-height: 42rpx;
}

.cloud-symbol {
  height: 40rpx;
  color: #0284c7;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.entry-meta {
  color: #667085;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 34rpx;
}
