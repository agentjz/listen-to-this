<view class="page import-existing-page">
  <view class="section page-head">
    <view class="title">导入材料</view>
    <view class="subtitle">从未归类材料中选择，移动到“{{targetLibraryName}}”。</view>
  </view>

  <view wx:if="{{isLoading}}" class="empty-state">正在加载</view>

  <view wx:elif="{{candidates.length === 0}}" class="empty-state">
    <view class="empty-title">未归类材料为空</view>
    <view class="empty-copy">先新建材料，再回到分类中导入。</view>
  </view>

  <view wx:else class="candidate-section">
    <view class="batch-toolbar">
      <view class="batch-count">已选择 {{selectedCount}} 个</view>
      <view class="batch-actions">
        <view class="batch-action" bindtap="selectAllCandidates">全选</view>
        <view class="batch-action" bindtap="clearSelection">取消</view>
      </view>
    </view>

    <view class="candidate-list">
      <view
        wx:for="{{candidates}}"
        wx:key="id"
        class="{{item.isSelected ? 'candidate-row selected' : 'candidate-row'}}"
        data-id="{{item.id}}"
        bindtap="toggleCandidateSelection"
      >
        <view class="candidate-check" data-id="{{item.id}}" catchtap="toggleCandidateSelection">{{item.isSelected ? '✓' : ''}}</view>
        <view class="candidate-main">
          <view class="candidate-title">{{item.title}}</view>
          <view class="candidate-copy">{{item.content}}</view>
        </view>
      </view>
    </view>

    <view class="{{isBatchMoving ? 'batch-submit moving' : 'batch-submit'}}" bindtap="importSelectedMaterials">
      {{isBatchMoving ? '导入中' : '导入已选'}}
    </view>
  </view>
</view>
