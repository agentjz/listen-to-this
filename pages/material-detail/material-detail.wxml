<view class="page">
  <view class="section">
    <view class="title">{{titleInput || '未命名材料'}}</view>
    <view class="subtitle">{{audios.length > 0 ? '已有音频' : '阅读材料'}}</view>
  </view>

  <view class="section panel stack">
    <input
      class="text-input"
      value="{{titleInput}}"
      bindinput="onTitleInput"
      placeholder="不填则自动命名"
      placeholder-class="input-placeholder"
    />
    <textarea
      class="content-input"
      value="{{contentInput}}"
      bindinput="onContentInput"
      placeholder="英文内容"
      placeholder-class="input-placeholder"
      auto-height="{{false}}"
    />
  </view>

  <view class="section panel audio-status">
    <view>
      <view class="audio-title">音频</view>
      <view class="audio-meta">{{audios.length > 0 ? '当前材料已绑定音频' : '当前材料未绑定音频'}}</view>
    </view>
    <van-button plain color="#38bdf8" custom-class="narrow-action" loading="{{isUploading}}" bindtap="uploadAudio">替换音频</van-button>
  </view>

  <view class="section audio-actions">
    <van-button color="#38bdf8" custom-class="audio-action" loading="{{isSaving}}" bindtap="saveMaterial">保存修改</van-button>
    <van-button wx:if="{{mode === 'cloud'}}" plain color="#38bdf8" custom-class="audio-action" loading="{{isGenerating}}" bindtap="generateAudio">生成音频</van-button>
  </view>
</view>
