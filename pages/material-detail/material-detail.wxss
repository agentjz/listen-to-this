.text-input {
  width: 100%;
  min-height: 96rpx;
  padding: 20rpx 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #172033;
  background: #ffffff;
  font-size: 28rpx;
  line-height: 48rpx;
}

.content-input {
  width: 100%;
  height: 480rpx;
  min-height: 480rpx;
  padding: 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #172033;
  background: #ffffff;
  font-size: 30rpx;
  line-height: 48rpx;
}

.audio-status {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.audio-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.audio-meta {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.audio-actions {
  display: flex;
  gap: 16rpx;
}

.audio-action {
  flex: 1;
  min-width: 0;
}

.narrow-action {
  flex: none;
}
