<view class="page practice-player-page">
  <view class="section page-head">
    <view class="title">{{title}}</view>
    <view class="subtitle">{{currentMaterial ? currentRoundText + ' · ' + currentMaterial.libraryName : '随机播放有音频材料'}}</view>
  </view>

  <view wx:if="{{isLoading}}" class="empty-state">正在加载</view>
  <view wx:elif="{{materials.length === 0}}" class="empty-state">
    <view class="empty-title">暂无可练习材料</view>
    <view class="empty-copy">当前范围没有可播放音频。</view>
  </view>

  <view wx:else class="practice-card">
    <view class="practice-main">
      <view class="material-title">{{currentMaterial.title}}</view>
      <view class="material-meta">{{currentMaterial.libraryName}} · {{currentRoundText}}</view>
    </view>

    <view class="control-grid">
      <view class="control-action primary" bindtap="togglePlay">
        <van-icon name="{{playingMaterialId === currentMaterial.id ? 'pause-circle-o' : 'play-circle-o'}}" />
        <text>{{playingMaterialId === currentMaterial.id ? '暂停' : (pausedMaterialId === currentMaterial.id ? '继续' : '播放')}}</text>
      </view>
      <view class="control-action" bindtap="restartCurrent">
        <van-icon name="replay" />
        <text>从头</text>
      </view>
      <view class="control-action" bindtap="nextMaterial">
        <van-icon name="arrow" />
        <text>下一条</text>
      </view>
      <view class="control-action" bindtap="toggleContent">
        <van-icon name="{{showContent ? 'closed-eye' : 'eye-o'}}" />
        <text>{{showContent ? '隐藏原文' : '查看原文'}}</text>
      </view>
    </view>

    <view class="playback-settings">
      <view class="setting-chip" bindtap="cyclePlaybackRate">倍速 {{playbackRateText}}</view>
      <view class="{{playbackSettings.singleLoopEnabled ? 'setting-chip active' : 'setting-chip'}}" bindtap="toggleSingleLoop">单条循环</view>
      <view class="{{playbackSettings.autoPlayNextEnabled ? 'setting-chip active' : 'setting-chip'}}" bindtap="toggleAutoPlayNext">自动下一条</view>
    </view>

    <view class="progress-row">
      <text class="time-text">{{currentTimeText}}</text>
      <slider
        class="progress-slider"
        value="{{progressPercent}}"
        min="0"
        max="100"
        step="1"
        block-size="16"
        activeColor="#38bdf8"
        backgroundColor="#d9e4ef"
        bindchanging="onProgressChanging"
        bindchange="onProgressChanged"
      />
      <text class="time-text">{{durationText}}</text>
    </view>

    <view wx:if="{{showContent}}" class="content-panel">
      <view class="content-text">{{currentMaterial.content}}</view>
    </view>
  </view>
</view>
