.materials-page {
  padding-bottom: 48rpx;
}

.page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.head-copy {
  min-width: 0;
  flex: 1;
}

.manage-toggle {
  width: 132rpx;
  height: 64rpx;
  flex: none;
  border-radius: 8rpx;
  color: #0284c7;
  background: #e0f2fe;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 64rpx;
  text-align: center;
}

.manage-panel {
  padding: 20rpx;
  border: 1rpx solid #e3e7f3;
  border-radius: 8rpx;
  background: #ffffff;
}

.import-action {
  height: 84rpx;
  border-radius: 8rpx;
  color: #ffffff;
  background: #38bdf8;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 84rpx;
  text-align: center;
}

.debug-panel {
  padding: 18rpx 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  background: #f0f9ff;
}

.debug-title {
  color: #0284c7;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.debug-line {
  margin-top: 6rpx;
  color: #475467;
  font-size: 22rpx;
  line-height: 32rpx;
  overflow-wrap: break-word;
}

.material-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.material-card {
  overflow: hidden;
  border: 1rpx solid #e3e7f3;
  border-radius: 8rpx;
  background: #ffffff;
  transition: transform 120ms ease, box-shadow 120ms ease, border-color 120ms ease;
}

.material-card.dragging {
  border-color: #38bdf8;
  box-shadow: 0 18rpx 44rpx rgba(56, 189, 248, 0.2);
  transform: scale(1.01);
}

.material-body {
  min-width: 0;
  padding: 28rpx 28rpx 22rpx;
}

.material-title {
  display: block;
  color: #172033;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
  word-break: normal;
  overflow-wrap: break-word;
}

.material-desc {
  margin-top: 10rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.material-footer {
  display: flex;
  border-top: 1rpx solid #eef1f7;
}

.footer-action {
  display: flex;
  min-width: 0;
  height: 84rpx;
  flex: 1;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 650;
}

.footer-action.play {
  color: #0284c7;
  background: #f0f9ff;
}

.footer-action.restart {
  color: #344054;
  background: #ffffff;
  border-left: 1rpx solid #eef1f7;
}

.manage-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  border-top: 1rpx solid #eef1f7;
}

.manage-action {
  min-width: 0;
  height: 76rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 76rpx;
  text-align: center;
  background: #ffffff;
}

.manage-action + .manage-action {
  border-left: 1rpx solid #eef1f7;
}

.manage-action.danger {
  color: #b42318;
}
