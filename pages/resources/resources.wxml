<view class="page">
  <view class="section page-head">
    <view class="head-copy">
      <view class="title">资源</view>
      <view class="subtitle">选择分类，或在管理模式新增分类。</view>
    </view>
    <view class="manage-toggle" bindtap="toggleManage">{{isManaging ? '完成' : '管理'}}</view>
  </view>

  <view class="section search-panel">
    <view class="search-bar">
      <input
        class="search-input"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="submitSearch"
        placeholder="搜索标题或正文"
        placeholder-class="input-placeholder"
      />
      <view class="search-button" bindtap="submitSearch">搜索</view>
    </view>
    <view wx:if="{{searchResults.length > 0}}" class="search-results">
      <view
        wx:for="{{searchResults}}"
        wx:key="id"
        class="search-result"
        data-id="{{item.id}}"
        data-library-id="{{item.libraryId}}"
        bindtap="openSearchResult"
      >
        <view class="search-title">{{item.title}}</view>
        <view class="search-meta">{{item.libraryName}} · {{item.hasAudio ? '有音频' : '阅读材料'}}</view>
      </view>
    </view>
    <view wx:if="{{searchKeyword && searchResults.length === 0}}" class="search-empty">没有找到材料</view>
  </view>

  <view wx:if="{{isManaging}}" class="section panel stack">
    <input
      class="name-input"
      value="{{newLibraryName}}"
      bindinput="onLibraryNameInput"
      placeholder="分类名称"
      placeholder-class="input-placeholder"
    />
    <van-button color="#38bdf8" block loading="{{isSaving}}" bindtap="saveLibrary">新增分类</van-button>
  </view>

  <view class="stack">
    <view wx:for="{{resources}}" wx:key="id" class="resource-row">
      <view wx:if="{{editingLibraryId === item.id}}" class="resource-edit">
        <input
          class="rename-input"
          value="{{editingLibraryName}}"
          bindinput="onRenameInput"
          placeholder="分类名称"
          placeholder-class="input-placeholder"
        />
        <view class="rename-actions">
          <view class="{{isRenaming ? 'rename-command primary busy' : 'rename-command primary'}}" bindtap="saveRename">
            {{isRenaming ? '保存中' : '保存'}}
          </view>
          <view class="rename-command muted" bindtap="cancelRename">取消</view>
        </view>
      </view>
      <view wx:else class="resource-main" data-id="{{item.id}}" bindtap="openMaterials">
        <view class="resource-name">{{item.name}}</view>
        <view class="resource-meta">{{item.materialCount}} 个材料</view>
      </view>
      <view wx:if="{{isManaging && editingLibraryId !== item.id && (item.canRename || item.canDelete)}}" class="resource-actions">
        <view wx:if="{{item.canRename}}" class="resource-icon-action" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="startRename">
          <van-icon name="edit" />
        </view>
        <view wx:if="{{item.canDelete}}" class="resource-icon-action danger" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="deleteLibrary">
          <van-icon name="delete-o" />
        </view>
      </view>
      <van-icon wx:if="{{!isManaging && editingLibraryId !== item.id}}" name="arrow" />
    </view>
  </view>
</view>
