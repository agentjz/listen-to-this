.page-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.head-copy {
  min-width: 0;
  flex: 1;
}

.manage-toggle {
  width: 132rpx;
  height: 64rpx;
  flex: none;
  border-radius: 8rpx;
  color: #0284c7;
  background: #e0f2fe;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 64rpx;
  text-align: center;
}

.name-input {
  width: 100%;
  min-height: 88rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #172033;
  background: #ffffff;
  font-size: 28rpx;
  line-height: 44rpx;
}

.search-panel {
  padding: 20rpx;
  border: 1rpx solid #e3e7f3;
  border-radius: 8rpx;
  background: #ffffff;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.search-input {
  width: 100%;
  min-height: 84rpx;
  min-width: 0;
  flex: 1;
  padding: 16rpx 22rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #172033;
  background: #f8fbff;
  font-size: 28rpx;
  line-height: 44rpx;
}

.search-button {
  width: 112rpx;
  height: 84rpx;
  flex: none;
  border-radius: 8rpx;
  color: #ffffff;
  background: #38bdf8;
  font-size: 26rpx;
  font-weight: 650;
  line-height: 84rpx;
  text-align: center;
}

.search-results {
  margin-top: 16rpx;
  border-top: 1rpx solid #eef1f7;
}

.search-result {
  padding: 18rpx 4rpx;
  border-bottom: 1rpx solid #eef1f7;
}

.search-title {
  color: #172033;
  font-size: 28rpx;
  font-weight: 650;
  line-height: 40rpx;
  overflow-wrap: break-word;
}

.search-meta {
  margin-top: 4rpx;
  color: #667085;
  font-size: 23rpx;
  line-height: 32rpx;
}

.search-empty {
  margin-top: 14rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
  text-align: center;
}

.resource-row {
  display: flex;
  min-height: 128rpx;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 26rpx;
  border: 1rpx solid #e3e7f3;
  border-radius: 8rpx;
  background: #ffffff;
  text-align: left;
}

.resource-main {
  min-width: 0;
  flex: 1;
}

.resource-edit {
  min-width: 0;
  flex: 1;
}

.rename-input {
  width: 100%;
  min-height: 76rpx;
  padding: 14rpx 18rpx;
  border: 1rpx solid #bae6fd;
  border-radius: 8rpx;
  color: #172033;
  background: #ffffff;
  font-size: 26rpx;
  line-height: 42rpx;
}

.rename-actions {
  display: grid;
  width: 100%;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 14rpx;
}

.rename-command {
  width: 100%;
  height: 64rpx;
  min-width: 0;
  padding: 0 12rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 64rpx;
  text-align: center;
  overflow-wrap: break-word;
}

.rename-command.primary {
  color: #ffffff;
  background: #38bdf8;
}

.rename-command.primary.busy {
  background: #94a3b8;
}

.rename-command.muted {
  color: #344054;
  background: #eef1f7;
}

.resource-name {
  color: #172033;
  font-size: 30rpx;
  font-weight: 650;
  line-height: 40rpx;
}

.resource-meta {
  margin-top: 6rpx;
  color: #667085;
  font-size: 24rpx;
  line-height: 34rpx;
}

.resource-actions {
  display: flex;
  flex: none;
  gap: 12rpx;
}

.resource-icon-action {
  width: 64rpx;
  height: 64rpx;
  flex: none;
  border-radius: 8rpx;
  color: #0284c7;
  background: #e0f2fe;
  font-size: 32rpx;
  line-height: 64rpx;
  text-align: center;
}

.resource-icon-action.danger {
  color: #b42318;
  background: #fff1f1;
}
