{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitAny": true,
    "noFallthroughCasesInSwitch": true,
    "noEmitOnError": true,
    "baseUrl": ".",
    "types": ["node"],
    "typeRoots": ["./typings", "./node_modules/@types"]
  },
  "include": [
    "app.ts",
    "pages/**/*.ts",
    "miniprogram/**/*.ts",
    "cloudfunctions/**/*.ts",
    "tests/**/*.ts",
    "typings/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "ref"
  ]
}
